# Imagem e ref do openclaw
OPENCLAW_IMAGE=vibestack-openclaw:latest
OPENCLAW_REF=main

# Gateway
OPENCLAW_GATEWAY_BIND=auto
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=

# Diretorio persistente no host (auth profiles, openclaw.json, workspace — tudo aqui).
# O ./install.sh resolve isso por SO: ~/.openclaw no Mac/Windows e /root/.openclaw
# na VPS (onde HOME=/root). So' mude se quiser um caminho custom.
OPENCLAW_DATA_DIR=/root/.openclaw

# Keyring — gerar com: openssl rand -hex 32
GOG_KEYRING_PASSWORD=

# --- Backends de modelos locais (Ollama e/ou LM Studio) --------------------
# O ./install.sh pergunta qual instalar. Estas flags sao BUILD ARGS: controlam
# o que o Dockerfile baixa (instala-se SO' o que estiver 'true'). O backend
# instalado SOBE no boot (o entrypoint detecta e inicia). Adicionar o outro
# depois exige novo `docker compose build`. (Re)start manual: `start-ollama` /
# `start-lmstudio` via `docker compose exec`.
INSTALL_OLLAMA=true
INSTALL_LMSTUDIO=false

# Ollama (instalado dentro do container openclaw-vibestack).
# Mesmo esquema do OPENCLAW_DATA_DIR: ./install.sh resolve por SO.
OLLAMA_DATA_DIR=/root/.ollama
# Modelo local do Ollama para baixar automaticamente no startup (ex: gemma4:26b)
OLLAMA_AUTO_PULL_MODEL=

# LM Studio — diretorio persistente dos modelos (montado em /root/.lmstudio/models).
# So' tem efeito se INSTALL_LMSTUDIO=true. ./install.sh resolve por SO.
LMSTUDIO_DATA_DIR=/root/.lmstudio

# Meta Ads — System User Token gerado no Business Manager
# (Business Settings -> System Users -> Generate Token, escopo ads_management/ads_read)
META_ACCESS_TOKEN=
# Ad account ativa para a CLI 'meta ads' (formato: act_123456789).
# Pode ficar vazio — agente descobre via list_ad_accounts.
META_AD_ACCOUNT_ID=

# AtlasCloud — hub de 300+ modelos (imagem/video/LLM) via MCP server OFICIAL
# (pacote npm 'atlascloud-mcp', instalado na imagem). Auth 100% por API key:
# sem login, sem volume — a chave aqui ja' sobrevive a restart/rebuild.
# Pegue em: https://www.atlascloud.ai/console/api-keys
ATLASCLOUD_API_KEY=

# Backblaze B2 — storage canonico de seeds e derivacoes do agente Criativo.
# Endpoint S3-compatible usado pelo middleware media_editor_mcp.py via boto3.
# Como obter:
#   1. Painel B2 -> "Application Keys" -> "Add a New Application Key".
#   2. Escolha um bucket (ou "All buckets") e capabilities listAllBucketNames +
#      listBuckets + readFiles + writeFiles + deleteFiles.
#   3. Copie keyID (vai em B2_KEY_ID) e applicationKey (vai em B2_APP_KEY).
#   4. O endpoint depende da regiao do bucket — veja em "Buckets" -> detalhes
#      (formato: https://s3.<region>.backblazeb2.com, ex: us-west-002).
# Estrutura de prefixos esperada no bucket:
#   inbox/    uploads humanos pendentes (dropbox para gravacoes solicitadas)
#   seeds/    midias-base classificadas: seeds/image/, seeds/video/, seeds/audio/
#   work/     derivacoes intermediarias do pipeline (work/<slug>/...)
#   final/    midias prontas para Meta Ads (estado pre-finalize)
#   requests/ pedidos pendentes de gravacao humana (JSON)
#   meta/     sidecar de lineage (criado automaticamente)
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_ENDPOINT_URL=https://s3.us-west-002.backblazeb2.com

# Higgsfield CLI — geracao de imagem/video e soul-id (agente Criativo).
# O CLI autentica via `higgsfield auth login` (OAuth no navegador, sem API key);
# o token fica em ~/.higgsfield. Este diretorio e' montado como volume p/ a sessao
# sobreviver a restart/rebuild (aluno loga 1x via SSH). Mesmo esquema do
# OPENCLAW_DATA_DIR: ./install.sh resolve por SO (~/.higgsfield no Mac, /root/.higgsfield na VPS).
# Login (1x):  docker exec -it openclaw-vibestack higgsfield auth login
# Conferir:    docker exec -it openclaw-vibestack higgsfield auth status
HIGGSFIELD_DATA_DIR=/root/.higgsfield

# Hermes Agent (NousResearch) — alternativa ao OpenClaw, no MESMO container.
# Roda um api_server OpenAI-compatible numa porta separada (coexiste com o OpenClaw).
# Acesso via SSH tunnel: ssh -N -L 8642:127.0.0.1:8642 root@VPS -> http://localhost:8642/v1
# As tools meta-ads/media-editor sao as mesmas do OpenClaw (mesmos middlewares).
# O provider/modelo NAO e' configurado pelo build — edite ${HERMES_DATA_DIR}/config.yaml
# ou rode `docker exec -it <cont> hermes model` depois do primeiro boot.
#
# Branch/tag/commit do repo NousResearch/hermes-agent clonado no build.
HERMES_REF=main
# Diretorio persistente do HERMES_HOME (config.yaml, .env, sessions, skills, memories).
# Mesmo esquema do OPENCLAW_DATA_DIR: ./install.sh resolve por SO (~/.hermes no Mac, /root/.hermes na VPS).
HERMES_DATA_DIR=/root/.hermes
# Porta do api_server OpenAI-compatible do Hermes (default 8642).
HERMES_API_PORT=8642
# Porta do dashboard web do Hermes (pagina de gestao/chat, default 9119).
# Acesso via SSH tunnel: ssh -N -L 9119:127.0.0.1:9119 root@VPS -> http://localhost:9119
HERMES_WEB_PORT=9119
# Chave do api_server — OBRIGATORIA pro Hermes subir na 8642 (Bearer token da API).
# Gerar com: openssl rand -hex 32
HERMES_API_SERVER_KEY=
# Autorizacao de usuario do gateway Hermes. Sem allowlist o default e' NEGAR
# (o bridge do WhatsApp recebe "not authorized" do api_server). Como o controle
# de quem fala no WhatsApp ja' e' o WA_BRIDGE_ALLOWED_NUMBERS, deixamos 'true'.
# Coloque 'false' se for plugar Telegram/Discord e quiser allowlist por plataforma.
GATEWAY_ALLOW_ALL_USERS=true
# Aprovacao de comandos do agente. Num canal headless (WhatsApp/api_server) nao ha
# quem responda o prompt de aprovacao -> o agente TRAVA ate dar timeout. 'off' = auto
# aprova tudo; 'smart' = aprova baixo risco; 'manual' = sempre pergunta (trava no canal).
HERMES_APPROVALS_MODE=off

# --- WhatsApp via GOWA (Go WhatsApp Web Multi-Device) ------------------------
# O GOWA roda como serviço no compose na porta 3000.
# Imagem oficial do GOWA
GOWA_IMAGE=aldinokemal2104/go-whatsapp-web-multidevice:latest
# Porta que o GOWA escuta no host (loopback para SSH tunnel / proxy reverso)
GOWA_PORT=3000
# URL base do GOWA dentro do container (DNS do compose)
GOWA_BASE_URL=http://gowa:3000
# Credenciais opcionais de Basic Auth para a API do GOWA (formato user:password)
GOWA_BASIC_AUTH=
# ID do dispositivo/sessão padrão no GOWA (opcional)
GOWA_DEVICE_ID=
# Proxy opcional para a conexão de saída do WhatsApp no GOWA (ex: http://proxy:port)
# O GOWA/Go herdará isso para fazer as conexões
GOWA_HTTP_PROXY=
GOWA_HTTPS_PROXY=

# Banco de dados PostgreSQL para persistência do GOWA (sessões e credenciais)
GOWA_PG_IMAGE=pgvector/pgvector:pg16
# Senha do Postgres para o GOWA (gerar com: openssl rand -hex 16)
POSTGRES_PASSWORD=
# Diretorio persistente do Postgres no host (./install.sh resolve por SO)
POSTGRES_DATA_DIR=/root/.gowa-pg

# Canal inbound do WhatsApp (bridge: webhook do GOWA -> agente -> resposta).
# Qual agente RESPONDE o canal (como o Telegram): 'hermes' (HTTP api_server) ou
# 'openclaw' (CLI `openclaw agent`). Troque aqui e reinicie pra mudar o cerebro.
WA_BRIDGE_AGENT=hermes
# (Opcional, modo openclaw) id do agente/binding do OpenClaw que atende o canal.
WA_BRIDGE_OPENCLAW_AGENT=
# O bridge escuta nesta porta (so' rede interna do compose; o gowa aponta
# WHATSAPP_WEBHOOK=http://openclaw-vibestack:<porta>/webhook automaticamente).
WA_BRIDGE_PORT=8765
# Tarefas longas (gerar criativo, multi tool-calls) podem levar minutos. Timeout (s) que o bridge espera o agente (0 = ILIMITADO, recomendado);
# e apos quantos s avisar "processando" (WA_BRIDGE_ACK_AFTER; 0 = nao avisar).
WA_BRIDGE_UPSTREAM_TIMEOUT=0
WA_BRIDGE_ACK_AFTER=20
# Numeros (CSV, so' digitos com DDI) que podem conversar com o agente pelo WhatsApp.
# VAZIO = qualquer numero que mandar mensagem fala com o agente. Recomendado preencher
# com o(s) seu(s) numero(s). Ex: 5511999999999,5521988888888
WA_BRIDGE_ALLOWED_NUMBERS=
